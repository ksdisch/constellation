# Constellation build-time environment.
# Copy to `.env` (gitignored) and uncomment to override defaults.

# Absolute relay URL the built clients connect to. Set this for the deployed
# build (e.g. the itch.io upload) so both clients target the public relay over
# TLS. Leave UNSET for local `npm run dev` — the clients then infer
# ws[s]://<page-host>:3081 from the LAN.
#
# VITE_RELAY_URL=wss://constellation-relay.fly.dev
